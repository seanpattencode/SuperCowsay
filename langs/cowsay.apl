#!/usr/bin/apl --script
r←(⎕ARG⍳⊂'--')↓⎕ARG
m←⊃('Hello, World!' (¯1↓∊r,¨⊂' '))[1+×≢r]
nl←⎕UCS 10
⍞←' ',((2+≢m)⍴'_'),nl,'< ',m,' >',nl,' ',((2+≢m)⍴'-'),nl,'        \   ^__^',nl,'         \  (oo)\_______',nl,'            (__)\       )\/\',nl,'                ||----w |',nl,'                ||     ||'
)OFF
